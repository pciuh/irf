def damfn(p,s):
    P,Q = (0,0)
    nb = int(len(p)/2)
    for i,b in enumerate(p[:nb]):
        P = P + b*s**(2*(i+1))

    for i,d in enumerate(p[nb:]):
        Q = Q + d*s**(2*(i))
    Q = Q + s**(len(p)+2)
    return(P/Q)

def damf(s,*p):
    P,Q = (0,0)
    nb = int(len(p)/2)
    for i,b in enumerate(p[:nb]):
        P = P + b*s**(2*(i+1))

    for i,d in enumerate(p[nb:]):
        Q = Q + d*s**(2*(i))
    Q = Q + s**(len(p)+2)
    return(P/Q)

def admf(s,*p):
    P,Q = (0,0)
    nb = int(len(p)/2)
    for i,b in enumerate(p[:nb]):
        P = P + b*s**(2*(i))

    for i,d in enumerate(p[nb:]):
        Q = Q + d*s**(2*(i))
    Q = Q + s**(len(p)+2)
    return(P/Q)

